# AlloyGen 2.0 — Environment Configuration
# Copy this file to .env and fill in your values

# --- LLM Provider (choose one: gemini, openai, claude) ---
LLM_PROVIDER=gemini

# Gemini (default)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
FLASH_MODEL=gemini-2.5-flash
PRO_MODEL=gemini-2.5-flash

# OpenAI (uncomment and set LLM_PROVIDER=openai)
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_FLASH_MODEL=gpt-4o-mini
# OPENAI_PRO_MODEL=gpt-4o

# Claude (uncomment and set LLM_PROVIDER=claude)
# CLAUDE_API_KEY=your_claude_api_key_here
# CLAUDE_FLASH_MODEL=claude-sonnet-4-6
# CLAUDE_PRO_MODEL=claude-opus-4-6

# --- Auth ---
JWT_SECRET_KEY=change-this-to-a-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///data/alloygen.db

# --- Training ---
# MODEL_TIMEOUT_SECONDS=300
# CV_FOLDS=5
# TEST_SIZE=0.2
# MIN_ROWS=10

# --- Upload ---
# MAX_UPLOAD_BYTES=52428800
